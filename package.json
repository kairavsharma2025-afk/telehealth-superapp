{
  "name": "telehealth-superapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI TeleHealth Super App — production-grade SaaS (learning project)",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/shared",
    "packages/design",
    "packages/api-gateway",
    "packages/auth-service",
    "packages/user-service",
    "packages/appointment-service",
    "packages/upload-service",
    "packages/notification-service",
    "packages/web-doctor",
    "packages/web-admin",
    "packages/mobile-patient",
    "packages/seed",
    "packages/e2e"
  ],
  "scripts": {
    "infra:up": "docker compose up -d postgres mongo minio",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres mongo minio",
    "db:up": "docker compose up -d postgres mongo",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres mongo",
    "db:psql": "docker compose exec postgres psql -U telehealth -d telehealth",
    "db:mongo": "docker compose exec mongo mongosh -u telehealth -p telehealth_dev_pw --authenticationDatabase admin",
    "db:seed": "npm -w @telehealth/seed run seed",
    "db:backup": "bash scripts/backup.sh",
    "db:restore": "bash scripts/restore.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b packages/shared && npm run typecheck --workspaces --if-present",
    "test:e2e": "npm -w @telehealth/e2e run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.11.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.12.2"
  },
  "overrides": {
    "@types/react": "~19.1.10"
  }
}
