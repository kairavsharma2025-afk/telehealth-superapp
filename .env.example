# =====================================================================
# TELEHEALTH SUPERAPP — environment template
# Copy this file to `.env` and fill in real values. NEVER commit .env.
# Each microservice will also have its own .env.example later (Phase 3).
# =====================================================================

# ----- Node environment -----
NODE_ENV=development
LOG_LEVEL=debug

# ----- PostgreSQL (local Docker) -----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=telehealth
POSTGRES_PASSWORD=telehealth_dev_pw
POSTGRES_DB=telehealth

# Connection string consumed by services (Postgres clients prefer this form)
DATABASE_URL=postgresql://telehealth:telehealth_dev_pw@localhost:5432/telehealth

# ----- MongoDB (local Docker) -----
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=telehealth
MONGO_PASSWORD=telehealth_dev_pw
MONGO_DB=telehealth_logs
MONGO_URL=mongodb://telehealth:telehealth_dev_pw@localhost:27017/telehealth_logs?authSource=admin

# ----- JWT / Auth (placeholders — generate real secrets per env) -----
# In prod, generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_me_with_64_hex_chars
JWT_REFRESH_SECRET=replace_me_with_64_hex_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ----- Service ports (local dev) -----
GATEWAY_PORT=4000
AUTH_PORT=4001
USER_PORT=4002
APPOINTMENT_PORT=4003
UPLOAD_PORT=4004
NOTIFICATION_PORT=4005

# ----- Object storage (MinIO locally, real S3 in Phase 7) -----
# These point at the MinIO container by default. In prod, swap S3_ENDPOINT to
# https://s3.<region>.amazonaws.com and use real IAM credentials.
S3_ENDPOINT=http://localhost:9000
S3_REGION=ap-south-1
S3_BUCKET=telehealth-uploads-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Public-facing endpoint that clients hit when they PUT to the presigned URL.
# Differs from S3_ENDPOINT only when the gateway/MinIO is behind a different
# hostname externally (e.g. localhost vs minio.local). For pure localhost dev
# leave equal to S3_ENDPOINT.
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Legacy AWS_* — keep around for Phase 7 wiring if you want a separate IAM key.
AWS_REGION=ap-south-1

# ----- Notification providers (filled in Phase 3) -----
SES_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
FCM_SERVER_KEY=

# ----- SSO (filled in Phase 3) -----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
