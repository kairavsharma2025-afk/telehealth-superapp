{
  "name": "@telehealth/api-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Public-facing entry point. Verifies JWTs and proxies to internal microservices.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@telehealth/shared": "0.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.12.7",
    "rimraf": "^5.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
