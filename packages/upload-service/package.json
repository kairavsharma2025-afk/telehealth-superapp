{
  "name": "@telehealth/upload-service",
  "version": "0.1.0",
  "private": true,
  "description": "Issues presigned S3 (MinIO) URLs for client-side uploads, tracks metadata.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "migrate": "tsx --env-file-if-exists=../../.env scripts/migrate.ts",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@telehealth/shared": "0.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.10",
    "rimraf": "^5.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}
