{
  "name": "@telehealth/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, errors, and utilities used by every Telehealth service",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
