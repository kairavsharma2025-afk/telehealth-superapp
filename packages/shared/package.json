  },
  "dependencies": {
    "express": "^4.21.1",
    "mongodb": "^6.10.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "pino-pretty": "^11.3.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  }
