{
  "name": "@telehealth/mobile-patient",
  "version": "0.1.0",
  "private": true,
  "description": "Patient-facing mobile app — Expo + React Native.",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
